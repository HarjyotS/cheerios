# =============================================================================
# Cherios
# =============================================================================
# Keep source, docs, and checked-in config clean.
# Keep generated output, local credentials, machine state, and diagnostics out.


# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/


# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
out/
dist/
build/
release/

.vite/
.electron-vite/
.cache/

*.tsbuildinfo


# -----------------------------------------------------------------------------
# Native Artifacts
# -----------------------------------------------------------------------------
resources/bin/system-audio-capture

native/SystemAudioCapture/.build/
native/SystemAudioCapture/Package.resolved


# -----------------------------------------------------------------------------
# Local Config And Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

dev-data/
.claude/settings.local.json


# -----------------------------------------------------------------------------
# Logs And Diagnostics
# -----------------------------------------------------------------------------
logs/
*.log

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# -----------------------------------------------------------------------------
# Test And Coverage Output
# -----------------------------------------------------------------------------
coverage/
playwright-report/
test-results/


# -----------------------------------------------------------------------------
# OS And Editor Noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

*.swp
*.swo

.idea/
.vscode/
